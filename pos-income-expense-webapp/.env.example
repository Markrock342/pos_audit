# Copy to `.env.local` (local) or Vercel → Settings → Environment Variables

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — scripts only (db:clear-daily-close, db:clear when RLS blocks DELETE)
# Never expose in client code or commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — integration tests against running server
# TEST_BASE_URL=http://localhost:3000
